# ORE Refined Configuration
# Copy this file to .env and fill in your values

# RPC URL - Your Solana RPC provider (Helius recommended)
RPC_URL=https://your-rpc-url.com

# Path to your Solana keypair file
KEYPAIR_PATH=/path/to/your/keypair.json

# Amount of SOL to deploy per round
PER_ROUND_DEPLOY_AMOUNT=0.1

# Deploy only in the final N slots of each round (default: 15)
REMAINING_SLOTS=15

# Expected ORE required to obtain 1 unclaimed ORE (default: 1.3)
# Higher = more frequent deployments, lower = stricter/fewer deployments
# Minimum is 0.9
ORE_REFINED_RATE=1.3
